@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Welcome Back</h1>
            <p>Log in to access Group2 Sport Project.</p>
        </div>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="form-group-custom">
                <label asp-for="Input.Email" class="form-label-custom"></label>
                <input asp-for="Input.Email" class="form-control-custom" autocomplete="username" aria-required="true" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Input.Password" class="form-label-custom"></label>
                <input asp-for="Input.Password" class="form-control-custom" autocomplete="current-password" aria-required="true" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="remember-row">
                <input class="form-check-input custom-check" asp-for="Input.RememberMe" />
                <label asp-for="Input.RememberMe" class="remember-label"></label>
            </div>

            <button id="login-submit" type="submit" class="auth-btn">Log In</button>

            <div class="auth-links">
                <a id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}