@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <h1>Create Account</h1>
            <p>Sign up to access Group2 Sport Project.</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

            <div class="name-row">
                <div class="form-group-custom">
                    <label asp-for="Input.FirstName" class="form-label-custom"></label>
                    <input asp-for="Input.FirstName" class="form-control-custom" autocomplete="given-name" />
                    <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                </div>

                <div class="form-group-custom">
                    <label asp-for="Input.LastName" class="form-label-custom"></label>
                    <input asp-for="Input.LastName" class="form-control-custom" autocomplete="family-name" />
                    <span asp-validation-for="Input.LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group-custom">
                <label asp-for="Input.Email" class="form-label-custom"></label>
                <input asp-for="Input.Email" class="form-control-custom" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Input.Password" class="form-label-custom"></label>
                <input asp-for="Input.Password" class="form-control-custom" autocomplete="new-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Input.ConfirmPassword" class="form-label-custom"></label>
                <input asp-for="Input.ConfirmPassword" class="form-control-custom" autocomplete="new-password" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button id="registerSubmit" type="submit" class="auth-btn">Create Account</button>

            <div class="auth-links">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Already have an account? Sign in</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}