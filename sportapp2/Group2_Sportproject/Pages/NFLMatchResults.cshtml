@page
@model Group2_Sportproject.Pages.NFLMatchResultsModel
@{
    ViewData["Title"] = "NFL Match Results";
}

<div class="container py-4">

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h2>NFL Match Results</h2>
        <a asp-page="/Index" class="btn btn-outline-light">Back Home</a>
    </div>

    <div class="nba-standings-card p-3 mb-4">
        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Home Team</th>
                        <th>Home Score</th>
                        <th>Away Score</th>
                        <th>Away Team</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var game in Model.Games)
                    {
                        <tr>
                            <td>@game.HomeTeam</td>
                            <td>
                                @if (game.HomeScore > game.AwayScore)
                                {
                                    <span class="fw-bold text-decoration-underline">@game.HomeScore</span>
                                }
                                else
                                {
                                    @game.HomeScore
                                }
                            </td>
                            <td>
                                @if (game.AwayScore > game.HomeScore)
                                {
                                    <span class="fw-bold text-decoration-underline">@game.AwayScore</span>
                                }
                                else
                                {
                                    @game.AwayScore
                                }
                            </td>
                            <td>@game.AwayTeam</td>
                            <td>@game.Status</td>
                            <td>@game.Date.ToLocalTime().ToString("MM/dd/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>