@page
@model Group2_Sportproject.Pages.NFLPlayersModel
<h1 class="display-4 mb-4">@Model.SelectedTeam Players</h1>

<div class="table-responsive">
    <form method="get" class="mb-3">
        <input type="hidden" name="team" value="@Model.SelectedTeam" />

        <div class="input-group">
            <input type="text"
                   name="SearchTerm"
                   value="@Model.SearchTerm"
                   class="form-control"
                   placeholder="Search player..." />

            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>
    <table class="table table-dark table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th>Team</th>
                <th>Pos</th>
                <th>GP</th>

                <!-- Passing -->
                <th>Pass Yds</th>
                <th>Pass TD</th>
                <th>INT</th>

                <!-- Rushing -->
                <th>Rush Yds</th>
                <th>Rush TD</th>

                <!-- Receiving -->
                <th>Rec Yds</th>
                <th>Rec TD</th>

                <!-- Defense -->
                <th>Tackles</th>
                <th>Sacks</th>
                <th>INT (Def)</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Players!= null && Model.Players.Any())
            {
                foreach (var p in Model.Players)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.Team</td>
                        <td>@p.Position</td>
                        <td>@(p.Played ?? 0)</td>

                        <!-- Passing -->
                        <td>@(p.PassingYards ?? 0)</td>
                        <td>@(p.PassingTouchdowns ?? 0)</td>
                        <td>@(p.PassingInterceptions ?? 0)</td>

                        <!-- Rushing -->
                        <td>@(p.RushingYards ?? 0)</td>
                        <td>@(p.RushingTouchdowns ?? 0)</td>

                        <!-- Receiving -->
                        <td>@(p.ReceivingYards ?? 0)</td>
                        <td>@(p.ReceivingTouchdowns ?? 0)</td>

                        <!-- Defense -->
                        <td>@(p.Tackles ?? 0)</td>
                        <td>@(p.Sacks ?? 0)</td>
                        <td>@(p.Interceptions ?? 0)</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="14" class="text-center text-muted">
                        No players found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>