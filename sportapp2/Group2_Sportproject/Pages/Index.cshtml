@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<section class="sports-home">
    <div class="sports-overlay"></div>

    <div class="sports-content">
        <div class="hero-text">
            <h1>Welcome to Sports Hub</h1>
            <p>
                Choose a league to explore teams, schedules, standings, and more.
            </p>
        </div>

        <div class="league-cards">

            <div class="league-card nba-card">
                <div class="league-card-inner">
                    <div class="logo-container">
                        <img src="/images/nba.png" />
                    </div>
                    <h2>NBA</h2>
                    <p>Fast-paced action and team data</p>

                    <a asp-page="/Teams/Index"
                       asp-route-league="nba"
                       class="league-btn nba-btn">
                        Explore NBA
                    </a>
                </div>
            </div>

            <div class="league-card nfl-card">
                <div class="league-card-inner">
                    <div class="logo-container">
                        <img src="/images/nfl2.png" />
                    </div>
                    <h2>NFL</h2>
                    <p>Game day matchups and league info</p>

                    <a asp-page="/Teams/Index"
                       asp-route-league="nfl"
                       class="league-btn nfl-btn">
                        Explore NFL
                    </a>
                </div>
            </div>

        </div>
    </div>
</section>