@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Group2_Sportproject.Data
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject ApplicationDbContext _context

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Group2 Sport Project</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg custom-navbar shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold text-white" asp-area="" asp-page="/Index">
                    Group2 Sport Project
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-lg-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-page="/Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-page="/Teams/Index">Teams</a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var profile = currentUser == null
                            ? null
                            : await _context.UserProfiles.FirstOrDefaultAsync(p => p.IdentityUserId == currentUser.Id);

                            var displayName = profile?.FirstName ?? User.Identity?.Name;

                            <li class="nav-item me-2">
                                <span class="nav-link text-white">Hello, @displayName</span>
                            </li>
                            <li class="nav-item">
                                <form method="post"
                                      asp-area="Identity"
                                      asp-page="/Account/Logout"
                                      asp-route-returnUrl="@Url.Page("/Index", new { area = "" })">
                                    <button type="submit" class="btn btn-light btn-sm rounded-pill px-3">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item me-2">
                                <a class="btn btn-outline-light btn-sm rounded-pill px-3"
                                   asp-area="Identity"
                                   asp-page="/Account/Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="btn btn-light btn-sm rounded-pill px-3"
                                   asp-area="Identity"
                                   asp-page="/Account/Register">Register</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-shell">
        <div class="container-fluid p-0">
            @RenderBody()
        </div>
    </main>

    <footer class="footer-bar">
        <div class="container text-center">
            &copy; 2026 - Group2 Sport Project
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>