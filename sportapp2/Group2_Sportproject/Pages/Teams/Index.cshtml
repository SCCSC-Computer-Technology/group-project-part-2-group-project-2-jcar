@page
@model Group2_Sportproject.Pages.Teams.IndexModel
@{
    ViewData["Title"] = "Teams";
}

<div class="container py-4">

    <div class="mb-4">
        <h1>
            @if (Model.League == "nba")
            {
                <text>NBA Standings</text>
            }
            else if (Model.League == "nfl")
            {
                <text>NFL Teams</text>
            }
            else
            {
                <text>Teams</text>
            }
        </h1>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">
            <strong>Error:</strong> @Model.ErrorMessage
        </div>
    }

    @if (Model.League == "nba")
    {
        <form method="get" class="nba-filter-bar mb-3">
            <input type="hidden" name="league" value="nba" />

            <div class="season-filter-group">
                <label for="season" class="season-label">Season</label>
                <select id="season" name="season" class="form-select season-select" onchange="this.form.submit()">
                    @foreach (var season in Model.AvailableSeasons)
                    {
                        if (season.Key == Model.SelectedSeason)
                        {
                            <option value="@season.Key" selected>@season.Value</option>
                        }
                        else
                        {
                            <option value="@season.Key">@season.Value</option>
                        }
                    }
                </select>
            </div>

            <div class="search-filter-group">
                <label for="teamSearch" class="season-label">Search</label>
                <input type="text"
                       id="teamSearch"
                       class="form-control standings-search"
                       placeholder="Search team..."
                       onkeyup="filterTeams()" />
            </div>

            <div class="back-home-filter-group">
                <label class="season-label d-block">&nbsp;</label>
                <a asp-page="/Index" class="btn btn-outline-light back-home-inline">Back Home</a>
            </div>
        </form>

        <div class="nba-standings-card">
            <ul class="nav nav-tabs standings-tabs mb-0" id="nbaStandingsTabs" role="tablist">
                <li class="nav-item standings-tab-item" role="presentation">
                    <button class="nav-link active"
                            id="east-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#east-pane"
                            type="button"
                            role="tab"
                            aria-controls="east-pane"
                            aria-selected="true">
                        Eastern Conference
                    </button>
                </li>

                <li class="nav-item standings-tab-item" role="presentation">
                    <button class="nav-link"
                            id="west-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#west-pane"
                            type="button"
                            role="tab"
                            aria-controls="west-pane"
                            aria-selected="false">
                        Western Conference
                    </button>
                </li>
            </ul>

            <div class="tab-content standings-tab-content" id="nbaStandingsTabContent">

                <div class="tab-pane fade show active"
                     id="east-pane"
                     role="tabpanel"
                     aria-labelledby="east-tab"
                     tabindex="0">

                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle standings-table mb-0">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Team</th>
                                    <th>W</th>
                                    <th>L</th>
                                    <th>PCT</th>
                                    <th>GB</th>
                                    <th>CONF</th>
                                    <th>HOME</th>
                                    <th>AWAY</th>
                                    <th>L10</th>
                                    <th>STRK</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var team in Model.EasternStandings)
                                {
                                    <tr>
                                        <td>@team.ConferenceRank</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@Model.GetNBALogoPath(team.Name)"
                                                     alt="@team.Name logo"
                                                     class="standings-logo"
                                                     onerror="this.style.display='none';" />

                                                <div>
                                                    <div class="fw-bold">@team.Name</div>
                                                    <small class="text-light">@team.City</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@team.Wins</td>
                                        <td>@team.Losses</td>
                                        <td>@team.Percentage.ToString("0.000")</td>
                                        <td>@Model.GetGamesBack(team, Model.EasternStandings)</td>
                                        <td>@team.ConferenceWins-@team.ConferenceLosses</td>
                                        <td>@team.HomeWins-@team.HomeLosses</td>
                                        <td>@team.AwayWins-@team.AwayLosses</td>
                                        <td>@team.LastTenWins-@team.LastTenLosses</td>
                                        <td>@Model.GetStreakText(team.Streak)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade"
                     id="west-pane"
                     role="tabpanel"
                     aria-labelledby="west-tab"
                     tabindex="0">

                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle standings-table mb-0">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>Team</th>
                                    <th>W</th>
                                    <th>L</th>
                                    <th>PCT</th>
                                    <th>GB</th>
                                    <th>CONF</th>
                                    <th>HOME</th>
                                    <th>AWAY</th>
                                    <th>L10</th>
                                    <th>STRK</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var team in Model.WesternStandings)
                                {
                                    <tr>
                                        <td>@team.ConferenceRank</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@Model.GetNBALogoPath(team.Name)"
                                                     alt="@team.Name logo"
                                                     class="standings-logo"
                                                     onerror="this.style.display='none';" />

                                                <div>
                                                    <div class="fw-bold">@team.Name</div>
                                                    <small class="text-light">@team.City</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>@team.Wins</td>
                                        <td>@team.Losses</td>
                                        <td>@team.Percentage.ToString("0.000")</td>
                                        <td>@Model.GetGamesBack(team, Model.WesternStandings)</td>
                                        <td>@team.ConferenceWins-@team.ConferenceLosses</td>
                                        <td>@team.HomeWins-@team.HomeLosses</td>
                                        <td>@team.AwayWins-@team.AwayLosses</td>
                                        <td>@team.LastTenWins-@team.LastTenLosses</td>
                                        <td>@Model.GetStreakText(team.Streak)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </div>
    }

@if (Model.League == "nfl")
{
        <form method="get" class="nba-filter-bar mb-3">
            <input type="hidden" name="league" value="nfl" />

            <div class="season-filter-group">
                <label for="nflSeason" class="season-label">Season</label>
                <select id="nflSeason" name="nflSeason" class="form-select season-select" onchange="this.form.submit()">
                    @foreach (var season in Model.AvailableNFLSeasons)
                    {
                        if (season.Key == Model.SelectedNFLSeason)
                        {
                            <option value="@season.Key" selected>@season.Value</option>
                        }
                        else
                        {
                            <option value="@season.Key">@season.Value</option>
                        }
                    }
                </select>
            </div>

            <div class="back-home-filter-group">
                <label class="season-label d-block">&nbsp;</label>
                <a asp-page="/Index" class="btn btn-outline-light back-home-inline">Back Home</a>
            </div>
        </form>

        <div class="nfl-standings-container">

            @foreach (var conference in new[] { "AFC", "NFC" })
            {
                <div class="conference-block mb-5">

                    <h2 class="conference-title">@conference</h2>

                    <div class="row">
                        @foreach (var division in new[] { "East", "North", "South", "West" })
                        {
                            var teams = Model.NFLStandings
                            .Where(t => t.Conference == conference && t.Division == division)
                            .OrderByDescending(t => t.Wins)
                            .ThenBy(t => t.Losses)
                            .ToList();

                            if (teams.Any())
                            {
                                <div class="col-md-6 mb-4">
                                    <div class="division-card">

                                        <h5 class="division-title">@division Division</h5>

                                        <table class="table table-dark table-hover align-middle mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Team</th>
                                                    <th>W</th>
                                                    <th>L</th>
                                                    <th>T</th>
                                                    <th>PCT</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var team in teams)
                                                {
                                                    <tr>
                                                        <td>
                                                            <div class="d-flex align-items-center">
                                                                <img src="@Model.GetNFLLogoPath(team.Team)"
                                                                     class="nfl-team-logo"
                                                                     onerror="this.src='/images/SportIcons/nfl.png';" />

                                                                <span class="fw-bold">@team.Team</span>
                                                            </div>
                                                        </td>
                                                        <td>@team.Wins</td>
                                                        <td>@team.Losses</td>
                                                        <td>@team.Ties</td>
                                                        <td>@(team.Percentage?.ToString("0.000") ?? "-")</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>

                                    </div>
                                </div>
                            }
                        }
                    </div>

                </div>
            }

        </div>
}
